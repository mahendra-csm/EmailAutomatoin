# Email Crawler Configuration
# Copy this to .env and update with your values

# Flask Settings
SECRET_KEY=your-secret-key-change-this
DEBUG=False
PORT=5000

# Authentication
USERNAME=admin
PASSWORD=admin123

# File Paths
UPLOAD_FOLDER=uploads
CRAWLER_PATH=/home/ubuntu/EmailScrapy-OG
WEBSITES_FILE=/home/ubuntu/EmailScrapy-OG/emailcrawler/websites.txt

# Git Configuration
GIT_EMAIL=jenkins@example.com
GIT_NAME=Jenkins Bot
GIT_BRANCH=main

# Docker Settings
DOCKER_REGISTRY=your-docker-registry
DOCKER_IMAGE_NAME=email-crawler
DOCKER_IMAGE_TAG=latest

# Jenkins Settings
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_API_TOKEN=your-jenkins-api-token

# Email Notifications (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=your-email@example.com
